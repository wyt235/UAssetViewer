<Window x:Class="UAssetViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:UAssetViewer.ViewModels"
        mc:Ignorable="d"
        Title="UAsset Viewer — DataTable / StringTable 查看器"
        Height="720" Width="1200" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- 布尔 → 可见性 转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 强调色 -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="#E8F1FB" />
        <SolidColorBrush x:Key="SidebarBg" Color="#FAFAFA" />
        <SolidColorBrush x:Key="HeaderBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F" />
        <SolidColorBrush x:Key="MutedText" Color="#888888" />

        <!-- 分组标题样式 -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="Margin" Value="8,12,8,4" />
        </Style>

        <!-- 文件列表项样式 -->
        <Style x:Key="AssetListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                Background="Transparent" CornerRadius="4" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 工具栏 -->
            <RowDefinition Height="*" />     <!-- 内容区 -->
            <RowDefinition Height="Auto" />  <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ==================== 顶部工具栏 ==================== -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- 左：打开目录 -->
                <Button DockPanel.Dock="Left" Content="📂 打开目录"
                        Command="{Binding OpenDirectoryCommand}"
                        IsEnabled="{Binding IsNotScanning}"
                        Style="{StaticResource PrimaryButton}" />

                <!-- 左：当前路径 -->
                <TextBlock DockPanel.Dock="Left" Text="{Binding CurrentDirectory}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{StaticResource MutedText}" FontSize="12"
                           TextTrimming="CharacterEllipsis" MaxWidth="500" />

                <!-- 右：搜索框 -->
                <Border DockPanel.Dock="Right" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="4,2"
                        Background="White" MinWidth="250">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="🔍" VerticalAlignment="Center"
                                   Margin="4,0" Foreground="{StaticResource MutedText}" />
                        <Button DockPanel.Dock="Right" Content="✕" FontSize="10"
                                Command="{Binding ClearSearchCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource MutedText}" Cursor="Hand"
                                Padding="6,2" VerticalAlignment="Center" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                 BorderThickness="0" VerticalAlignment="Center" FontSize="13"
                                 Background="Transparent" />
                    </DockPanel>
                </Border>

                <!-- 中：扫描进度 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="120" Height="14" Value="{Binding ScanProgressPercent}"
                                 Minimum="0" Maximum="100" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ScanProgress}" Foreground="{StaticResource MutedText}"
                               FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ==================== 主内容区 ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧面板：文件列表 ===== -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- DataTable 分组 -->
                        <TextBlock Style="{StaticResource GroupHeaderStyle}">
                            <Run Text="📊 DataTable" />
                            <Run Text="{Binding TotalDataTables, StringFormat=' ({0})'}"
                                 Foreground="{StaticResource MutedText}" />
                        </TextBlock>
                        <ListBox ItemsSource="{Binding DataTableAssets}"
                                 SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource AssetListBoxItem}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Summary}"
                                                   Foreground="{StaticResource MutedText}"
                                                   FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FilePath}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- StringTable 分组 -->
                        <TextBlock Style="{StaticResource GroupHeaderStyle}">
                            <Run Text="📝 StringTable" />
                            <Run Text="{Binding TotalStringTables, StringFormat=' ({0})'}"
                                 Foreground="{StaticResource MutedText}" />
                        </TextBlock>
                        <ListBox ItemsSource="{Binding StringTableAssets}"
                                 SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource AssetListBoxItem}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Summary}"
                                                   Foreground="{StaticResource MutedText}"
                                                   FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FilePath}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 分割线可拖拽 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"
                          Cursor="SizeWE" />

            <!-- ===== 右侧面板：数据表格 ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- 标题栏 -->
                    <RowDefinition Height="*" />     <!-- 表格 -->
                </Grid.RowDefinitions>

                <!-- 表格标题 -->
                <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="12,8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TableInfo}"
                                   Foreground="{StaticResource MutedText}" FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TableHeader}" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </Border>

                <!-- 错误提示 -->
                <Border Grid.Row="1" Background="#FFF3F3" Padding="12,8"
                        VerticalAlignment="Top" Margin="8"
                        CornerRadius="4" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </Border>

                <!-- 加载中 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="8" />
                    <TextBlock Text="加载中..." HorizontalAlignment="Center" Margin="0,8"
                               Foreground="{StaticResource MutedText}" />
                </StackPanel>

                <!-- 数据表格 -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredView}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserResizeRows="False"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F9FBFD"
                          RowBackground="White"
                          HorizontalGridLinesBrush="#EEE"
                          BorderThickness="0"
                          FontSize="13"
                          ColumnHeaderHeight="32"
                          RowHeight="28"
                          Margin="0"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F4F8" />
                            <Setter Property="Foreground" Value="#333" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="BorderBrush" Value="#DDD" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                    <Setter Property="Foreground" Value="#000" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ==================== 底部状态栏 ==================== -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedText}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>